# =============================================================================
# ml-clustering-lab — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/
.env/

# ---------------------------------------------------------------------------
# Data directories (add your own raw/processed datasets locally)
# ---------------------------------------------------------------------------
data/raw/
data/processed/

# ---------------------------------------------------------------------------
# Output artefacts (generated by the pipeline; never commit)
# ---------------------------------------------------------------------------
outputs/figures/
outputs/reports/
outputs/runs/

# ---------------------------------------------------------------------------
# Jupyter notebooks checkpoints
# ---------------------------------------------------------------------------
notebooks/.ipynb_checkpoints/
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Tooling caches
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.log

# ---------------------------------------------------------------------------
# IDE / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.DS_Store
Thumbs.db
