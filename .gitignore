# =============================================================================
# ml-clustering-lab — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/
.env/

# ---------------------------------------------------------------------------
# Data directories (add your own raw/processed datasets locally)
# .gitkeep files are kept to preserve the directory structure in git
# ---------------------------------------------------------------------------
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# ---------------------------------------------------------------------------
# Output artefacts (generated by the pipeline; never commit)
# .gitkeep files are kept to preserve the directory structure in git
# ---------------------------------------------------------------------------
outputs/figures/*
!outputs/figures/.gitkeep
outputs/reports/*
!outputs/reports/.gitkeep
outputs/runs/*
!outputs/runs/.gitkeep

# ---------------------------------------------------------------------------
# Jupyter notebooks checkpoints
# ---------------------------------------------------------------------------
notebooks/.ipynb_checkpoints/
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Tooling caches
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.log

# ---------------------------------------------------------------------------
# IDE / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.DS_Store
Thumbs.db
